# Base API URL. You can provide either with or without /api.
# The app normalizes this to include /api for REST calls.
VITE_API_URL=http://localhost:5000/api

# Optional. If omitted, socket host is derived from VITE_API_URL.
# Set this only when your websocket host differs from your API host.
VITE_SOCKET_URL=http://localhost:5000